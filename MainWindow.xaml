<metro:MetroWindow
    x:Class="wada.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:views="clr-namespace:wada.Views"
    Title="Wada"
    Height="720" Width="1100"
    WindowStartupLocation="CenterScreen">

    <metro:MetroWindow.LeftWindowCommands>
        <metro:WindowCommands>
            <Button x:Name="BtnDashboard" Content="Dashboard" />
            <Button x:Name="BtnProjects" Content="Projects" />
            <Button x:Name="BtnClients" Content="Clients" />
            <Button x:Name="BtnEarnings" Content="Earnings" />
            <Button x:Name="BtnInvoices" Content="Invoices" />
            <Button x:Name="BtnReports" Content="Reports" />
        </metro:WindowCommands>
    </metro:MetroWindow.LeftWindowCommands>

    <ContentControl x:Name="MainContentFrame" Margin="0" />

</metro:MetroWindow>