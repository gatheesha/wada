<metro:MetroWindow
    x:Class="wada.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:views="clr-namespace:wada.Views"
    Title="Wada Wada Wada Wada Wada Wada..."
    Height="720" Width="1100"
    WindowStartupLocation="CenterScreen">

    <metro:MetroWindow.Resources>
        <!-- Nav button style: bold + slightly brighter when Tag="active" -->
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Opacity"    Value="0.7" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="active">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Opacity"    Value="1.0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </metro:MetroWindow.Resources>

    <metro:MetroWindow.LeftWindowCommands>
        <metro:WindowCommands>
            <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource NavButtonStyle}" />
            <Button x:Name="BtnProjects"  Content="Projects"  Style="{StaticResource NavButtonStyle}" />
            <Button x:Name="BtnClients"   Content="Clients"   Style="{StaticResource NavButtonStyle}" />
            <Button x:Name="BtnEarnings"  Content="Earnings"  Style="{StaticResource NavButtonStyle}" />
            <Button x:Name="BtnInvoices"  Content="Invoices"  Style="{StaticResource NavButtonStyle}" />
            <Button x:Name="BtnReports"   Content="Reports"   Style="{StaticResource NavButtonStyle}" />
        </metro:WindowCommands>
    </metro:MetroWindow.LeftWindowCommands>

    <ContentControl x:Name="MainContentFrame" Margin="0" />

</metro:MetroWindow>
