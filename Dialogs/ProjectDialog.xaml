<metro:MetroWindow x:Class="wada.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Project" Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1"
        ShowMinButton="False" ShowMaxRestoreButton="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Name -->
        <Label Grid.Row="0" Content="Project Name *" />
        <TextBox Grid.Row="1" x:Name="TxtName"
                 metro:TextBoxHelper.Watermark="Enter project name…"
                 metro:TextBoxHelper.ClearTextButton="True"
                 Margin="0,0,0,10" />

        <!-- Description -->
        <Label Grid.Row="2" Content="Description" />
        <TextBox Grid.Row="3" x:Name="TxtDescription"
                 metro:TextBoxHelper.Watermark="Enter description…"
                 Height="56" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10" />

        <!-- Date / Time / Duration / Status row -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="Start Date" Padding="0,0,0,2" />
                <DatePicker x:Name="DpStartDate" SelectedDateFormat="Short" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Label Content="Time (HH:mm)" Padding="0,0,0,2" />
                <TextBox x:Name="TxtStartTime"
                         Text="09:00" MaxLength="5"
                         HorizontalContentAlignment="Center"
                         metro:TextBoxHelper.Watermark="09:00" />
            </StackPanel>

            <StackPanel Grid.Column="4">
                <Label Content="Duration (Days)" Padding="0,0,0,2" />
                <metro:NumericUpDown x:Name="NudDuration"
                                     Value="7" Minimum="1"
                                     HideUpDownButtons="False" />
            </StackPanel>

            <StackPanel Grid.Column="6">
                <Label Content="Status" Padding="0,0,0,2" />
                <ComboBox x:Name="CmbStatus"
                          Style="{DynamicResource MahApps.Styles.ComboBox}">
                    <ComboBoxItem Content="Active" />
                    <ComboBoxItem Content="On Hold" />
                    <ComboBoxItem Content="Completed" />
                    <ComboBoxItem Content="Cancelled" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Clients label -->
        <Label Grid.Row="5" Content="Clients" />

        <!-- Clients list -->
        <ListBox Grid.Row="6" x:Name="LstClients"
                 SelectionMode="Multiple"
                 Margin="0,0,0,10"
                 MinHeight="80"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource MahApps.Brushes.Gray7}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource MahApps.Styles.ListBoxItem}">
                    <Setter Property="Padding" Value="8,5" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="OkButton_Click" IsDefault="True" />
            <Button Content="Cancel" Width="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</metro:MetroWindow>