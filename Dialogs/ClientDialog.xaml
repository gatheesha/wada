<metro:MetroWindow x:Class="wada.Dialogs.ClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Client Information" Height="280" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1"
        ShowMinButton="False" ShowMaxRestoreButton="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Name *" />
        <TextBox Grid.Row="1" x:Name="TxtName"
                 metro:TextBoxHelper.Watermark="Enter client name…"
                 metro:TextBoxHelper.ClearTextButton="True"
                 Margin="0,0,0,10" />

        <Label Grid.Row="2" Content="Mobile Number" />
        <TextBox Grid.Row="3" x:Name="TxtContact"
                 metro:TextBoxHelper.Watermark="Enter mobile number…"
                 metro:TextBoxHelper.ClearTextButton="True"
                 Margin="0,0,0,10" />

        <Label Grid.Row="4" Content="Email Address" />
        <TextBox Grid.Row="5" x:Name="TxtEmail"
                 metro:TextBoxHelper.Watermark="Enter email address…"
                 metro:TextBoxHelper.ClearTextButton="True"
                 Margin="0,0,0,10" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="OkButton_Click" IsDefault="True" />
            <Button Content="Cancel" Width="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</metro:MetroWindow>