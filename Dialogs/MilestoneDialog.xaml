<metro:MetroWindow x:Class="wada.Dialogs.MilestoneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Add Milestone" Height="280" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        BorderThickness="1"
        ShowMinButton="False" ShowMaxRestoreButton="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Milestone Name *" />
        <TextBox Grid.Row="1" x:Name="TxtDescription"
                 metro:TextBoxHelper.Watermark="Enter milestone name…"
                 Margin="0,0,0,10" />
        <Label Grid.Row="2" Content="Price *" />
        <TextBox Grid.Row="3" x:Name="TxtPrice"
                 metro:TextBoxHelper.Watermark="Enter price…"
                 Margin="0,0,0,10" />
        <Label Grid.Row="4" Content="Deadline" />
        <DatePicker Grid.Row="5" x:Name="DpDeadline" Margin="0,0,0,10" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="OkButton_Click" IsDefault="True" />
            <Button Content="Cancel" Width="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</metro:MetroWindow>
