<UserControl x:Class="wada.Views.EarningsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:vm="clr-namespace:wada.ViewModels">

    <UserControl.DataContext>
        <vm:EarningsViewModel x:Name="ViewModel" />
    </UserControl.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Summary cards -->
            <RowDefinition Height="Auto" />   <!-- Toolbar -->
            <RowDefinition Height="*"    />   <!-- Table -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  ROW 0 — Summary Cards                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="0" Rows="1" Margin="0,0,0,14">

            <Border
                    Margin="0,0,8,0" Padding="16,12" Background="#33F472D0">
                <StackPanel>
                    <TextBlock Text="TOTAL EARNINGS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalEarningsDisplay}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border 
                    Margin="0,0,8,0" Padding="16,12" Background="#33EB2F2F">
                <StackPanel>
                    <TextBlock Text="TOTAL EXPENSES" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalExpensesDisplay}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border
                    Margin="0,0,8,0" Padding="16,12" Background="#33808080">
                <StackPanel>
                    <TextBlock Text="PENDING" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding PendingAmountDisplay}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border
                    Margin="0" Padding="16,12" Background="#3372F49E">
                <StackPanel>
                    <TextBlock Text="NET BALANCE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding NetBalanceDisplay}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  ROW 1 — Toolbar                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,10">

            <!-- Action buttons (left) -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="＋ Add Record"
                        Command="{Binding AddEarningCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Padding="12,6" Margin="0,0,6,0" />
                <Button Content="✎ Edit"
                        Command="{Binding EditRecordCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Padding="12,6" Margin="0,0,6,0" />
                <Button Content="✕ Delete"
                        Command="{Binding DeleteRecordCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Padding="12,6" />
            </StackPanel>

            <!-- Time-range filter tabs (right) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="This Week" Command="{Binding FilterThisWeekCommand}" Padding="12,6" Margin="0,0,4,0">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFilterThisWeek}" Value="True">
                          <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                          <Setter Property="Foreground" Value="White" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button Content="This Month"
                        Command="{Binding FilterThisMonthCommand}"
                        Padding="12,6" Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFilterThisMonth}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="All Time"
                        Command="{Binding FilterAllTimeCommand}"
                        Padding="12,6">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFilterAllTime}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </DockPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  ROW 2 — Finance Table                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Records}"
                  SelectedItem="{Binding SelectedRecord}"
                  Style="{DynamicResource MahApps.Styles.ListView}"
                  BorderThickness="0">
            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Date" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DateDisplay}" FontSize="13" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Type" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,3" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FinanceType}" Value="Expense">
                                                    <Setter Property="Background" Value="#E53935" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FinanceType}" Value="Pending">
                                                    <Setter Property="Background" Value="#F57C00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding FinanceType}"
                                               Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Description" Width="340">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Amount" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AmountDisplay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FinanceType}" Value="Expense">
                                                    <Setter Property="Foreground" Value="#E53935" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FinanceType}" Value="Pending">
                                                    <Setter Property="Foreground" Value="#F57C00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</UserControl>
