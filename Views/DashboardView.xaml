<UserControl x:Class="wada.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:vm="clr-namespace:wada.ViewModels">

    <UserControl.DataContext>
        <vm:DashboardViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Quick Stats -->
            <UniformGrid Grid.Row="0" Rows="1" Margin="0,0,0,20">
                <Border Padding="16" Background="#33F472D0" CornerRadius="6" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE PROJECTS" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="12" FontSize="28" FontWeight="Bold"/>
                        <!-- TODO: Bind later if needed -->
                    </StackPanel>
                </Border>
                <Border Padding="16" Background="#3372F49E" CornerRadius="6" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="UPCOMING DEADLINES" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{Binding UpcomingTasks.Count}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Earnings Chart -->
            <GroupBox Grid.Row="1" Header="Earnings Overview" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Month" Padding="16,6" Margin="0,0,6,0"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Command="{Binding SetThisMonthCommand}"/>
                        <Button Content="Year" Padding="16,6" Margin="0,0,6,0"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Command="{Binding SetThisYearCommand}"/>
                        <Button Content="All" Padding="16,6"
                                Style="{DynamicResource MahApps.Styles.Button.Square}"
                                Command="{Binding SetAllTimeCommand}"/>
                    </StackPanel>

                    <lvc:CartesianChart Grid.Row="1"
                    Series="{Binding EarningsSeries}"
                    LegendLocation="Top">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Period" Labels="{Binding XLabels}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Amount ($)" LabelFormatter="{Binding CurrencyFormatter}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Upcoming Tasks -->
                <GroupBox Grid.Column="0" Header="Upcoming Tasks" Margin="0,0,8,0">
                    <ListView ItemsSource="{Binding UpcomingTasks}" 
                              Style="{DynamicResource MahApps.Styles.ListView}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Task" DisplayMemberBinding="{Binding Name}" Width="300"/>
                                <GridViewColumn Header="Deadline" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Deadline, StringFormat={}{0:MMM dd, yyyy}}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Countdown" DisplayMemberBinding="{Binding CountdownText}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
                <GroupBox Grid.Column="1" Header="Active Projects" Margin="8,0,0,0">
                    <ListView ItemsSource="{Binding ActiveProjects}" 
                  Style="{DynamicResource MahApps.Styles.ListView}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Project" DisplayMemberBinding="{Binding Name}" Width="220"/>
                                <GridViewColumn Header="Status" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,3" CornerRadius="3" 
                                        Background="{DynamicResource MahApps.Brushes.Accent}">
                                                <TextBlock Text="{Binding Status}" 
                                               Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Deadline" DisplayMemberBinding="{Binding DeadlineText}" Width="140"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>