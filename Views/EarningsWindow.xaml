<Window x:Class="wada.Views.EarningsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Earnings &amp; Expenses" Height="500" Width="850" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Search Description:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="TxtSearch" Width="200" Margin="0,0,15,0" TextChanged="FilterInputs_Changed"/>

            <TextBlock Text="Categorize Type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CboFilterType" Width="120" SelectionChanged="FilterInputs_Changed">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Earning"/>
                <ComboBoxItem Content="Expense"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="DGEarnings" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionChanged="DGEarnings_SelectionChanged" Margin="0,0,15,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C}}" Width="100"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Use a Border to provide Background and Padding (StackPanel does not have Padding property) -->
        <Border Grid.Row="1" Grid.Column="1" Background="#F9F9F9" Padding="10">
            <StackPanel>
                <TextBlock Text="Transaction Details Form" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Type:"/>
                <ComboBox x:Name="CboFormType" Margin="0,5,0,10">
                    <ComboBoxItem Content="Earning" IsSelected="True"/>
                    <ComboBoxItem Content="Expense"/>
                </ComboBox>

                <TextBlock Text="Amount:"/>
                <TextBox x:Name="TxtAmount" Margin="0,5,0,10"/>

                <TextBlock Text="Date:"/>
                <DatePicker x:Name="DpDate" Margin="0,5,0,10"/>

                <TextBlock Text="Description:"/>
                <TextBox x:Name="TxtDescription" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,5,0,15"/>

                <TextBlock Text="Client:"/>
                <ComboBox x:Name="CboClient" Margin="0,5,0,10" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                <TextBlock Text="Project:"/>
                <ComboBox x:Name="CboProject" Margin="0,5,0,15" SelectedValuePath="Id" DisplayMemberPath="Name"/>

                <UniformGrid Columns="2" Rows="2" Height="70">
                    <Button Content="Add New" Margin="2" Click="BtnAdd_Click"/>
                    <Button Content="Update Selected" Margin="2" Click="BtnUpdate_Click"/>
                    <Button Content="Delete Selected" Margin="2" Click="BtnDelete_Click"/>
                    <Button Content="Clear Form" Margin="2" Click="BtnClear_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>   