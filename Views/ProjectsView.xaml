<UserControl x:Class="wada.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:wada.ViewModels">

    <UserControl.DataContext>
        <vm:ProjectsViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left: project list -->
            <ColumnDefinition Width="280" MinWidth="180" />
            <ColumnDefinition Width="4" />
            <!-- Right: detail panel -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  LEFT PANEL — Project List                      -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
                <Button Content="Add Project"    Command="{Binding AddProjectCommand}"    Margin="0,0,4,0" />
                <Button Content="Edit"           Command="{Binding EditProjectCommand}"   Margin="0,0,4,0" />
                <Button Content="Delete"         Command="{Binding DeleteProjectCommand}" />
            </StackPanel>

            <!-- Search -->
            <TextBox Grid.Row="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4,2,4,4"
                     xml:space="preserve" />

            <!-- Project list -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Projects}"
                     SelectedItem="{Binding SelectedProject}"
                     Margin="4,0,4,4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Status}" />
                            <TextBlock Text="{Binding DeadlineText}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

        <!-- ═══════════════════════════════════════════════ -->
        <!--  RIGHT PANEL — Project Detail                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="2">

            <!-- Placeholder when nothing selected -->
            <TextBlock Text="Select a project to view details."
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding IsDetailVisible,
                                    Converter={StaticResource BoolToVisibilityInverseConverter}}" />

            <!-- Detail content -->
            <Grid Visibility="{Binding IsDetailVisible,
                               Converter={StaticResource BoolToVisibilityConverter}}"
                  Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Project header -->
                    <RowDefinition Height="Auto" />
                    <!-- Linked clients -->
                    <RowDefinition Height="Auto" />
                    <!-- Milestone/Task toolbar -->
                    <RowDefinition Height="*"    />
                    <!-- Flat list -->
                </Grid.RowDefinitions>

                <!-- Project header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{Binding SelectedProject.Name}"
                               FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedProject.Description}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Status: " FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProject.Status}" />
                        <TextBlock Text="    " />
                        <TextBlock Text="Deadline: " FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProject.DeadlineText}" />
                    </StackPanel>

                    <!-- Linked clients -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Clients: " FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding LinkedClients}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,8,0">
                                        <Run Text="{Binding Name}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <Separator Grid.Row="1" Margin="0,0,0,4" />

                <!-- Milestone / Task toolbar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Add Milestone" Command="{Binding AddMilestoneCommand}" Margin="0,0,4,0" />
                </StackPanel>

                <!-- Flat list: milestones as bold headers, tasks beneath -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DetailItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- ── Milestone header row ── -->
                                <Grid>
                                    <!-- Milestone header -->
                                    <Border Visibility="{Binding IsMilestoneHeader,
                                                         Converter={StaticResource BoolToVisibilityConverter}}"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="Gray"
                                            Margin="0,8,0,2"
                                            Padding="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Milestone.Description}"
                                                       FontWeight="Bold" />
                                            <Button Grid.Column="1"
                                                    Content="+ Task"
                                                    Margin="4,0"
                                                    Command="{Binding DataContext.AddTaskCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Milestone.Id}" />
                                            <Button Grid.Column="2"
                                                    Content="Delete"
                                                    Command="{Binding DataContext.DeleteItemCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>

                                    <!-- Task row -->
                                    <Grid Visibility="{Binding IsMilestoneHeader,
                                                       Converter={StaticResource BoolToVisibilityInverseConverter}}"
                                          Margin="16,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsCompleted}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,6,0"
                                                  Command="{Binding DataContext.ToggleTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}" />

                                        <!-- Task name + description -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Task.Name}" />
                                            <TextBlock Text="{Binding Task.Description}"
                                                       FontSize="11"
                                                       Foreground="Gray"
                                                       Visibility="{Binding Task.Description,
                                                                    Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>

                                        <!-- Countdown -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Task.CountdownText}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0" />

                                        <!-- Delete task -->
                                        <Button Grid.Column="3"
                                                Content="Delete"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.DeleteItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
