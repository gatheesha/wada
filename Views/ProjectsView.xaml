<UserControl x:Class="wada.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:vm="clr-namespace:wada.ViewModels">

    <UserControl.DataContext>
        <vm:ProjectsViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════ -->
        <!--  LEFT PANEL — Project List             -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                <Button Content="+ Add"
                        Command="{Binding AddProjectCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Margin="0,0,4,0" Padding="12,6" />
                <Button Content="Edit"
                        Command="{Binding EditProjectCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Margin="0,0,4,0" Padding="12,6" />
                <Button Content="Delete"
                        Command="{Binding DeleteProjectCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Padding="12,6" />
            </StackPanel>

            <!-- Search -->
            <TextBox Grid.Row="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     metro:TextBoxHelper.Watermark="Search projects..."
                     metro:TextBoxHelper.ClearTextButton="True"
                     Margin="8,0,8,6" />

            <!-- Project list -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Projects}"
                     SelectedItem="{Binding SelectedProject}"
                     BorderThickness="0"
                     Background="Transparent"
                     Margin="4,0,4,4">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource MahApps.Styles.ListBoxItem}">
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock Text="{Binding Status}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                       Margin="0,2,0,0" />
                            <TextBlock Text="{Binding DeadlineText}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource MahApps.Brushes.Gray8}" />

        <!-- ══════════════════════════════════════ -->
        <!--  RIGHT PANEL — Project Detail          -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="2" Margin="12,8,12,8">

            <!-- Placeholder when nothing selected -->
            <TextBlock Text="Select a project to view details."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                       Visibility="{Binding IsDetailVisible,
                                    Converter={StaticResource BoolToVisibilityInverseConverter}}" />

            <!-- Detail content -->
            <Grid Visibility="{Binding IsDetailVisible,
                               Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Project header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{Binding SelectedProject.Name}"
                               FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="{Binding SelectedProject.Description}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                               Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="{DynamicResource MahApps.Brushes.Accent}"
                                CornerRadius="3" Padding="8,3" Margin="0,0,8,0">
                            <TextBlock Text="{Binding SelectedProject.Status}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{DynamicResource MahApps.Brushes.Gray8}"
                                CornerRadius="3" Padding="8,3">
                            <TextBlock Text="{Binding SelectedProject.DeadlineText}"
                                       FontSize="11" />
                        </Border>
                    </StackPanel>

                    <!-- Linked clients -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Clients: "
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <ItemsControl ItemsSource="{Binding LinkedClients}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource MahApps.Brushes.Gray8}"
                                            CornerRadius="3" Padding="8,3" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding Name}" FontSize="11" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Separator Grid.Row="1"
                           Background="{DynamicResource MahApps.Brushes.Gray8}"
                           Margin="0,0,0,8" />

                <!-- Milestone toolbar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="+ Add Milestone"
                            Command="{Binding AddMilestoneCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                            Padding="12,6" />
                </StackPanel>

                <!-- Flat list: milestones + tasks -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DetailItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>

                                    <!-- Milestone header row -->
                                    <Border Visibility="{Binding IsMilestoneHeader,
                                                         Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{DynamicResource MahApps.Brushes.Accent4}"
                                            CornerRadius="4"
                                            Margin="0,10,0,2"
                                            Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Milestone.Description}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Content="+ Task"
                                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                                    Padding="8,3" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.AddTaskCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Milestone.Id}" />
                                            <Button Grid.Column="2"
                                                    Content="Delete"
                                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                                    Padding="8,3"
                                                    Command="{Binding DataContext.DeleteItemCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>

                                    <!-- Task row -->
                                    <Border Visibility="{Binding IsMilestoneHeader,
                                                         Converter={StaticResource BoolToVisibilityInverseConverter}}"
                                            Background="{DynamicResource MahApps.Brushes.Gray9}"
                                            CornerRadius="4"
                                            Margin="16,2,0,2"
                                            Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <metro:ToggleSwitch Grid.Column="0"
                                                                IsOn="{Binding IsCompleted}"
                                                                OnContent="" OffContent=""
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,10,0"
                                                                Command="{Binding DataContext.ToggleTaskCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Task.Name}" FontSize="13" />
                                                <TextBlock Text="{Binding Task.Description}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                                           Visibility="{Binding Task.Description,
                                                                        Converter={StaticResource StringToVisibilityConverter}}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Task.CountdownText}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"
                                                       Margin="12,0" />

                                            <Button Grid.Column="3"
                                                    Content="Delete"
                                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                                    Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteItemCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</UserControl>