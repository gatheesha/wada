<UserControl x:Class="wada.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:vm="clr-namespace:wada.ViewModels">

    <UserControl.DataContext>
        <vm:ReportsViewModel />
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="This Month" Padding="20,8" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding SetThisMonthCommand}"/>
            <Button Content="This Year" Padding="20,8" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding SetThisYearCommand}"/>
            <Button Content="All Time" Padding="20,8"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding SetAllTimeCommand}"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Earnings &amp; Expenses Trend">
            <lvc:CartesianChart Series="{Binding Series}"
                                                                LegendLocation="Top">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Period" Labels="{Binding Labels}"/>
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Amount ($)" LabelFormatter="{Binding CurrencyFormatter}"/>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </GroupBox>
    </Grid>
</UserControl>